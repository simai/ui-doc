{
    "name": "docara-site",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vite --host 0.0.0.0",
        "watch": "vite build --watch --mode development",
        "prod": "vite build --mode production",
        "docs:build": "bin/build-docs-production.sh",
        "docs:integrity": "${PHP_BINARY:-php} bin/check-docs-integrity.php",
        "docs:rendered-links": "${PHP_BINARY:-php} bin/check-built-docs-links.php",
        "translate": "php vendor/bin/docara translate",
        "transpatetest": "php vendor/bin/docara translate --test",
        "init": "php vendor/bin/docara init",
        "postinstall": "node source/_core/copy-template-configs.js"
    },
    "devDependencies": {
        "@hotwired/turbo": "^8.0.13",
        "docsearch.js": "^2.6.3",
        "eslint": "^9.29.0",
        "fast-glob": "^3.2.12",
        "highlight.js": "^10.5.0",
        "@fontsource-variable/inter": "^5.2.8",
        "markdown-it-attrs": "^4.3.1",
        "normalize-scss": "^8.0.0",
        "postcss": "^8.4.40",
        "postcss-import": "^14.0.2",
        "sass": "^1.89.2",
        "tailwindcss": "^3.4.6",
        "vite": "^7.2.7"
    },
    "dependencies": {
        "fuse.js": "^7.1.0"
    }
}
